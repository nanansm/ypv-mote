{
  "name": "ypv-mote",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3004",
    "build": "next build",
    "start": "next start -p 3004",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate-locale": "tsx src/db/migrate-locale.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:check": "node -e \"const db=require('better-sqlite3')((process.env.DATABASE_URL||'file:./dev.db').replace('file:',''));console.log({config:db.prepare('SELECT count(*) as c FROM eligibility_config').get(),questions:db.prepare('SELECT count(*) as c FROM form_questions').get(),legal:db.prepare('SELECT count(*) as c FROM legal_pages').get(),settings:db.prepare('SELECT count(*) as c FROM app_settings').get(),emails:db.prepare('SELECT count(*) as c FROM email_templates').get()});\"",
    "db:studio": "drizzle-kit studio",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/eligibility/engine.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.3",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-sanitize": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
