# ─── Database ────────────────────────────────────────────────────────────────
# Production: mount /data as a persistent volume in Docker
DATABASE_URL=file:/data/ypv.db
# Local dev (uncomment):
# DATABASE_URL=file:./dev.db

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004
APP_URL=http://localhost:3004

# ─── Admin (Phase 2 — set now for readiness) ─────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login

# ─── Better-auth (Phase 2) ───────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3004

# ─── Optional: override DB-stored SMTP settings ──────────────────────────────
# These take priority over values stored in app_settings table.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# ─── Optional: override DB-stored API keys ───────────────────────────────────
GROQ_API_KEY=
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SHEET_ID=
